generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model achievements {
  id                Int                 @id @default(autoincrement())
  slug              String              @unique @db.VarChar(50)
  name              String              @db.VarChar(100)
  description       String?
  icon_url          String?
  criteria_type     String?             @db.VarChar(50)
  criteria_value    Int?
  rarity            String?             @default("common") @db.VarChar(20)
  points            Int?                @default(10)
  is_active         Boolean?            @default(true)
  user_achievements user_achievements[]
}

model activity_feed {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id       String        @db.Uuid
  activity_type activity_type
  title         String        @db.VarChar(255)
  description   String?
  project_id    String?       @db.Uuid
  pattern_id    String?       @db.Uuid
  post_id       String?       @db.Uuid
  metadata      Json?         @default("{}")
  is_public     Boolean?      @default(true)
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  patterns      patterns?     @relation(fields: [pattern_id], references: [id], onUpdate: NoAction)
  posts         posts?        @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects      projects?     @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_activity_feed_created")
  @@index([activity_type], map: "idx_activity_feed_type")
  @@index([user_id], map: "idx_activity_feed_user")
}

model ai_pattern_sessions {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id              String    @db.Uuid
  pattern_id           String?   @db.Uuid
  session_type         String?   @db.VarChar(50)
  input_parameters     Json?
  conversation_history Json?
  generated_pattern    Json?
  status               String?   @default("active") @db.VarChar(50)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  patterns             patterns? @relation(fields: [pattern_id], references: [id], onUpdate: NoAction)
  users                users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model chart_conversion_jobs {
  id                   String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id              String             @db.Uuid
  pattern_id           String?            @db.Uuid
  written_instructions String
  stitch_count         Int?
  row_count            Int?
  generated_chart_id   String?            @db.Uuid
  status               processing_status? @default(pending)
  error_message        String?
  created_at           DateTime?          @default(now()) @db.Timestamptz(6)
  completed_at         DateTime?          @db.Timestamptz(6)
  pattern_charts       pattern_charts?    @relation(fields: [generated_chart_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patterns             patterns?          @relation(fields: [pattern_id], references: [id], onUpdate: NoAction)
  users                users              @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model chart_symbols {
  id           Int         @id @default(autoincrement())
  symbol       String      @db.VarChar(10)
  name         String      @db.VarChar(50)
  abbreviation String?     @db.VarChar(20)
  description  String?
  svg_path     String?
  unicode_char String?     @db.VarChar(10)
  category     String?     @db.VarChar(50)
  craft_type   craft_type? @default(both)

  @@unique([symbol, craft_type])
}

model comments {
  id                String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String          @db.Uuid
  post_id           String?         @db.Uuid
  project_id        String?         @db.Uuid
  pattern_id        String?         @db.Uuid
  parent_comment_id String?         @db.Uuid
  content           String
  like_count        Int?            @default(0)
  reply_count       Int?            @default(0)
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?       @default(now()) @db.Timestamptz(6)
  deleted_at        DateTime?       @db.Timestamptz(6)
  comments          comments?       @relation("commentsTocomments", fields: [parent_comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  other_comments    comments[]      @relation("commentsTocomments")
  patterns          patterns?       @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  posts             posts?          @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects          projects?       @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users             users           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  likes             likes[]
  notifications     notifications[]

  @@index([pattern_id], map: "idx_comments_pattern")
  @@index([post_id], map: "idx_comments_post")
  @@index([project_id], map: "idx_comments_project")
}

model designer_profiles {
  user_id           String    @id @db.Uuid
  shop_name         String?   @db.VarChar(100)
  shop_slug         String?   @unique @db.VarChar(100)
  shop_description  String?
  shop_policies     String?
  refund_policy     String?
  banner_url        String?
  logo_url          String?
  support_email     String?   @db.VarChar(255)
  stripe_account_id String?   @db.VarChar(255)
  stripe_onboarded  Boolean?  @default(false)
  paypal_email      String?   @db.VarChar(255)
  tax_id            String?   @db.VarChar(100)
  total_sales       Int?      @default(0)
  total_revenue     Decimal?  @default(0) @db.Decimal(12, 2)
  average_rating    Decimal?  @db.Decimal(3, 2)
  review_count      Int?      @default(0)
  vacation_mode     Boolean?  @default(false)
  vacation_message  String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  users             users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model follows {
  id                                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  follower_id                       String    @db.Uuid
  following_id                      String    @db.Uuid
  created_at                        DateTime? @default(now()) @db.Timestamptz(6)
  users_follows_follower_idTousers  users     @relation("follows_follower_idTousers", fields: [follower_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_follows_following_idTousers users     @relation("follows_following_idTousers", fields: [following_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([follower_id, following_id])
  @@index([follower_id], map: "idx_follows_follower")
  @@index([following_id], map: "idx_follows_following")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model friendships {
  id                                    String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  requester_id                          String             @db.Uuid
  addressee_id                          String             @db.Uuid
  status                                friendship_status? @default(pending)
  created_at                            DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at                            DateTime?          @default(now()) @db.Timestamptz(6)
  accepted_at                           DateTime?          @db.Timestamptz(6)
  users_friendships_addressee_idTousers users              @relation("friendships_addressee_idTousers", fields: [addressee_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_friendships_requester_idTousers users              @relation("friendships_requester_idTousers", fields: [requester_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([requester_id, addressee_id])
  @@index([addressee_id], map: "idx_friendships_addressee")
  @@index([requester_id], map: "idx_friendships_requester")
  @@index([status], map: "idx_friendships_status")
}

model group_members {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  group_id  String    @db.Uuid
  user_id   String    @db.Uuid
  role      String?   @default("member") @db.VarChar(20)
  joined_at DateTime? @default(now()) @db.Timestamptz(6)
  groups    groups    @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([group_id, user_id])
  @@index([group_id], map: "idx_group_members_group")
  @@index([user_id], map: "idx_group_members_user")
}

model group_posts {
  id            String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  group_id      String        @db.Uuid
  user_id       String        @db.Uuid
  title         String?       @db.VarChar(255)
  content       String
  content_type  content_type? @default(discussion)
  is_pinned     Boolean?      @default(false)
  is_locked     Boolean?      @default(false)
  like_count    Int?          @default(0)
  comment_count Int?          @default(0)
  created_at    DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?     @default(now()) @db.Timestamptz(6)
  deleted_at    DateTime?     @db.Timestamptz(6)
  groups        groups        @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users         users         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([group_id], map: "idx_group_posts_group")
}

model groups {
  id                 String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name               String          @db.VarChar(150)
  slug               String          @unique @db.VarChar(150)
  description        String?
  rules              String?
  cover_image_url    String?
  icon_url           String?
  visibility         visibility?     @default(public)
  requires_approval  Boolean?        @default(false)
  posting_permission String?         @default("members") @db.VarChar(20)
  member_count       Int?            @default(0)
  post_count         Int?            @default(0)
  created_by         String          @db.Uuid
  created_at         DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?       @default(now()) @db.Timestamptz(6)
  group_members      group_members[]
  group_posts        group_posts[]
  users              users           @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  knit_alongs        knit_alongs[]
  notifications      notifications[]

  @@index([slug], map: "idx_groups_slug")
}

model kal_clues {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  kal_id       String      @db.Uuid
  clue_number  Int
  title        String?     @db.VarChar(200)
  description  String?
  instructions String?
  release_date DateTime?   @db.Timestamptz(6)
  is_released  Boolean?    @default(false)
  created_at   DateTime?   @default(now()) @db.Timestamptz(6)
  knit_alongs  knit_alongs @relation(fields: [kal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model kal_participants {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  kal_id      String      @db.Uuid
  user_id     String      @db.Uuid
  project_id  String?     @db.Uuid
  joined_at   DateTime?   @default(now()) @db.Timestamptz(6)
  finished_at DateTime?   @db.Timestamptz(6)
  knit_alongs knit_alongs @relation(fields: [kal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects    projects?   @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([kal_id, user_id])
}

model knit_alongs {
  id                String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name              String             @db.VarChar(200)
  slug              String             @unique @db.VarChar(200)
  description       String?
  rules             String?
  pattern_ids       String[]           @db.Uuid
  start_date        DateTime?          @db.Date
  end_date          DateTime?          @db.Date
  sign_up_deadline  DateTime?          @db.Date
  has_mystery_clues Boolean?           @default(false)
  has_prizes        Boolean?           @default(false)
  prize_description String?
  host_id           String             @db.Uuid
  host_group_id     String?            @db.Uuid
  visibility        visibility?        @default(public)
  participant_count Int?               @default(0)
  finished_count    Int?               @default(0)
  cover_image_url   String?
  created_at        DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?          @default(now()) @db.Timestamptz(6)
  kal_clues         kal_clues[]
  kal_participants  kal_participants[]
  groups            groups?            @relation(fields: [host_group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users              @relation(fields: [host_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notifications     notifications[]
}

model likes {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  post_id    String?   @db.Uuid
  project_id String?   @db.Uuid
  pattern_id String?   @db.Uuid
  comment_id String?   @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  comments   comments? @relation(fields: [comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patterns   patterns? @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  posts      posts?    @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects   projects? @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, comment_id])
  @@unique([user_id, pattern_id])
  @@unique([user_id, post_id])
  @@unique([user_id, project_id])
  @@index([user_id], map: "idx_likes_user")
}

model needle_brands {
  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String         @db.VarChar(100)
  website_url  String?        @db.VarChar(255)
  is_verified  Boolean?       @default(false)
  user_needles user_needles[]
}

model needle_size_chart {
  id      Int     @id @default(autoincrement())
  size_mm Decimal @db.Decimal(4, 2)
  size_us String? @db.VarChar(10)
  size_uk String? @db.VarChar(10)
  size_jp String? @db.VarChar(10)
  hook_us String? @db.VarChar(10)
  hook_uk String? @db.VarChar(10)
}

model notifications {
  id                                  String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                             String            @db.Uuid
  type                                notification_type
  actor_id                            String?           @db.Uuid
  post_id                             String?           @db.Uuid
  project_id                          String?           @db.Uuid
  pattern_id                          String?           @db.Uuid
  comment_id                          String?           @db.Uuid
  group_id                            String?           @db.Uuid
  kal_id                              String?           @db.Uuid
  achievement_id                      Int?
  title                               String?           @db.VarChar(255)
  message                             String?
  data                                Json?
  is_read                             Boolean?          @default(false)
  read_at                             DateTime?         @db.Timestamptz(6)
  created_at                          DateTime?         @default(now()) @db.Timestamptz(6)
  users_notifications_actor_idTousers users?            @relation("notifications_actor_idTousers", fields: [actor_id], references: [id], onUpdate: NoAction)
  comments                            comments?         @relation(fields: [comment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  groups                              groups?           @relation(fields: [group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  knit_alongs                         knit_alongs?      @relation(fields: [kal_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  patterns                            patterns?         @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  posts                               posts?            @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projects                            projects?         @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_notifications_user_idTousers  users             @relation("notifications_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, is_read, created_at(sort: Desc)], map: "idx_notifications_user")
}

model pattern_abbreviations {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pattern_id    String   @db.Uuid
  abbreviation  String   @db.VarChar(20)
  meaning       String   @db.VarChar(255)
  display_order Int?     @default(0)
  patterns      patterns @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model pattern_annotations {
  id               String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id          String            @db.Uuid
  pattern_id       String            @db.Uuid
  page_number      Int?
  section_id       String?           @db.Uuid
  row_id           String?           @db.Uuid
  x_percent        Decimal?          @db.Decimal(5, 2)
  y_percent        Decimal?          @db.Decimal(5, 2)
  annotation_type  String?           @db.VarChar(50)
  color            String?           @db.VarChar(7)
  content          String?
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @default(now()) @db.Timestamptz(6)
  patterns         patterns          @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pattern_rows     pattern_rows?     @relation(fields: [row_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pattern_sections pattern_sections? @relation(fields: [section_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users            users             @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id, pattern_id], map: "idx_pattern_annotations")
}

model pattern_charts {
  id                    String                  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pattern_id            String                  @db.Uuid
  section_id            String?                 @db.Uuid
  name                  String?                 @db.VarChar(100)
  description           String?
  width_stitches        Int
  height_rows           Int
  chart_data            Json
  symbol_legend         Json?
  image_url             String?
  read_rs_right_to_left Boolean?                @default(true)
  read_ws_right_to_left Boolean?                @default(false)
  first_row_number      Int?                    @default(1)
  row_numbering_side    String?                 @default("right") @db.VarChar(10)
  display_order         Int?                    @default(0)
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  chart_conversion_jobs chart_conversion_jobs[]
  patterns              patterns                @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pattern_sections      pattern_sections?       @relation(fields: [section_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([pattern_id], map: "idx_pattern_charts_pattern")
}

model pattern_favorites {
  user_id    String    @db.Uuid
  pattern_id String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  patterns   patterns  @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([user_id, pattern_id])
}

model pattern_images {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pattern_id    String    @db.Uuid
  image_url     String
  thumbnail_url String?
  caption       String?
  is_cover      Boolean?  @default(false)
  display_order Int?      @default(0)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  patterns      patterns  @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model pattern_listings {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  pattern_id    String          @unique @db.Uuid
  price         Decimal         @db.Decimal(10, 2)
  currency      String?         @default("USD") @db.VarChar(3)
  sale_price    Decimal?        @db.Decimal(10, 2)
  sale_start    DateTime?       @db.Timestamptz(6)
  sale_end      DateTime?       @db.Timestamptz(6)
  status        listing_status? @default(draft)
  sales_count   Int?            @default(0)
  revenue       Decimal?        @default(0) @db.Decimal(12, 2)
  preview_pages Int?            @default(1)
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @default(now()) @db.Timestamptz(6)
  patterns      patterns        @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  purchases     purchases[]
}

model pattern_queue {
  id              String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id         String         @db.Uuid
  pattern_id      String         @db.Uuid
  size_id         String?        @db.Uuid
  priority        Int?           @default(0)
  notes           String?
  planned_yarn_id String?        @db.Uuid
  created_at      DateTime?      @default(now()) @db.Timestamptz(6)
  patterns        patterns       @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user_stash      user_stash?    @relation(fields: [planned_yarn_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pattern_sizes   pattern_sizes? @relation(fields: [size_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users           users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([user_id, pattern_id])
}

model pattern_reading_progress {
  id                          String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id                     String            @db.Uuid
  pattern_id                  String            @db.Uuid
  project_id                  String?           @db.Uuid
  current_page                Int?
  current_section_id          String?           @db.Uuid
  current_row_id              String?           @db.Uuid
  selected_size_id            String?           @db.Uuid
  show_only_selected_size     Boolean?          @default(true)
  highlight_size_instructions Boolean?          @default(true)
  zoom_level                  Int?              @default(100)
  last_read_at                DateTime?         @default(now()) @db.Timestamptz(6)
  projects                    projects?         @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reading_progress_project")
  pattern_rows                pattern_rows?     @relation(fields: [current_row_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pattern_sections            pattern_sections? @relation(fields: [current_section_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  patterns                    patterns          @relation(fields: [pattern_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
