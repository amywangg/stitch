  project_id              String                    @db.Uuid
  pattern_section_id      String?                   @db.Uuid
  name                    String                    @db.VarChar(100)
  section_type            section_type?
  display_order           Int?                      @default(0)
  current_row             Int?                      @default(0)
  total_rows              Int?
  is_estimated_total      Boolean?                  @default(false)
  target_measurement_cm   Decimal?                  @db.Decimal(5, 2)
  current_measurement_cm  Decimal?                  @db.Decimal(5, 2)
  last_measured_at_row    Int?
  next_measure_at_row     Int?
  current_repeat          Int?                      @default(0)
  total_repeats           Int?
  rows_per_repeat         Int?
  is_active               Boolean?                  @default(false)
  is_completed            Boolean?                  @default(false)
  started_at              DateTime?                 @db.Timestamptz(6)
  completed_at            DateTime?                 @db.Timestamptz(6)
  time_spent_minutes      Int?                      @default(0)
  counter_haptic_feedback Boolean?                  @default(true)
  counter_sound_enabled   Boolean?                  @default(true)
  counter_voice_enabled   Boolean?                  @default(false)
  counter_auto_advance    Boolean?                  @default(false)
  notes                   String?
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  project_measurements    project_measurements[]
  project_notes           project_notes[]
  project_repeat_progress project_repeat_progress[]
  project_row_completions project_row_completions[]
  pattern_sections        pattern_sections?         @relation(fields: [pattern_section_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects                projects                  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  project_time_sessions   project_time_sessions[]
  row_counter_history     row_counter_history[]

  @@index([project_id], map: "idx_project_sections_project")
}

