generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

model users {
  id               String  @id @default(uuid())
  clerk_id         String  @unique
  email            String  @unique
  username         String  @unique
  display_name     String?
  avatar_url       String?
  bio              String?
  location         String?
  website          String?
  craft_preference String  @default("both") // "knitting" | "crochet" | "both"
  experience_level String? // "beginner" | "intermediate" | "advanced"
  is_pro           Boolean @default(false)
  username_changed_at DateTime? // cooldown: one change per 30 days
  activity_sharing Json?   // { project_started, project_completed, stash_added, row_milestone, pattern_queued, ... } — null = all on

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  subscription        subscriptions?
  ravelry_connection  ravelry_connections?
  projects            projects[]
  patterns            patterns[]
  pattern_folders     pattern_folders[]
  pattern_queue       pattern_queue[]
  posts               posts[]
  post_bookmarks      post_bookmarks[]
  comments            comments[]
  likes               likes[]
  followers           follows[]                @relation("following")
  following           follows[]                @relation("follower")
  notifications       notifications[]          @relation("recipient")
  sent_notifications  notifications[]          @relation("sender")
  stash               user_stash[]
  needles             user_needles[]
  supplies            user_supplies[]
  tutorial_progress   user_tutorial_progress[]
  onboarding          user_onboarding?
  saved_patterns      saved_patterns[]
  pdf_uploads         pdf_uploads[]
  activity_events     activity_events[]
  pattern_reviews     pattern_reviews[]
  crafting_sessions   crafting_sessions[]
  measurements        user_measurements?

  @@index([clerk_id])
  @@index([username])
}

// ─── Subscriptions ────────────────────────────────────────────────────────────

model subscriptions {
  id            String    @id @default(uuid())
  user_id       String    @unique
  revenuecat_id String?   @unique
  plan          String    @default("free")   // "free" | "plus" | "pro"
  status        String    @default("active") // "active" | "expired" | "cancelled"
  period_type   String?   // "monthly" | "yearly" | "lifetime"
  product_id    String?   // e.g. "com.stitchmarker.pro.monthly"
  store         String?   // "app_store" | "play_store" | "stripe"
  expires_at    DateTime?
  original_purchase_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ─── Ravelry OAuth ────────────────────────────────────────────────────────────

model ravelry_connections {
  id               String    @id @default(uuid())
  user_id          String    @unique
  ravelry_username String
  access_token     String    // AES-256 encrypted
  token_secret     String    // AES-256 encrypted
  synced_at           DateTime?
  import_status       String    @default("idle") // "idle" | "importing" | "done" | "error"
  import_error        String?
  import_stats        Json?     // { projects, patterns, queue, stash, needles } counts
  sync_to_ravelry     Boolean   @default(true) // user-controlled write-back toggle
  // Per-type sync timestamps — enables incremental sync per data type
  stash_synced_at     DateTime?
  projects_synced_at  DateTime?
  queue_synced_at     DateTime?
  needles_synced_at   DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ─── Yarn & Stash ─────────────────────────────────────────────────────────────

model yarn_companies {
  id         String   @id @default(uuid())
  name       String   @unique
  website    String?
  created_at DateTime @default(now())

  yarns yarns[]
}

// Catalog of known yarns (shared across all users)
model yarns {
  id                String  @id @default(uuid())
  company_id        String?
  name              String
  colorway          String?
  // "lace" | "fingering" | "sport" | "dk" | "worsted" | "aran" | "bulky" | "super_bulky"
  weight            String?
  fiber_content     String?
  yardage_per_skein Int?
  grams_per_skein   Int?
  ravelry_id        String?  @unique
  image_url         String?
  created_at        DateTime @default(now())

  company      yarn_companies? @relation(fields: [company_id], references: [id], onDelete: SetNull)
  stash_items  user_stash[]
  project_yarn project_yarns[]
}

// User's personal yarn inventory
model user_stash {
  id         String   @id @default(uuid())
  user_id    String
  yarn_id    String
  colorway   String?  // override colorway (e.g. dyed by user)
  skeins     Float    @default(1)
  grams      Int?
  notes      String?
  status     String   @default("in_stash") // "in_stash" | "used_up" | "gifted" | "for_sale"
  photo_url  String?  // user-uploaded photo of their yarn
  photo_path String?  // storage path for deletion
  ravelry_id String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user         users           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  yarn         yarns           @relation(fields: [yarn_id], references: [id], onDelete: Cascade)
  project_yarn project_yarns[]

  @@unique([user_id, ravelry_id])
  @@index([user_id])
}

// Which yarn(s) are used in a project
model project_yarns {
  id            String  @id @default(uuid())
  project_id    String
  yarn_id       String?
  stash_item_id String?
  // Free-text fallback for Ravelry imports without a matching yarn catalog entry
  name_override String?
  colorway      String?
  skeins_used   Float?

  project    projects    @relation(fields: [project_id], references: [id], onDelete: Cascade)
  yarn       yarns?      @relation(fields: [yarn_id], references: [id], onDelete: SetNull)
  stash_item user_stash? @relation(fields: [stash_item_id], references: [id], onDelete: SetNull)

  @@index([project_id])
}

// ─── Tool Catalog (Needles/Hooks Product Database) ───────────────────────────

// Shared catalog of needle/hook/tool manufacturers
model tool_brands {
  id         String   @id @default(uuid())
  name       String   @unique // "ChiaoGoo", "Knit Pro", "Addi"
  website    String?
  logo_url   String?  // brand logo image
  created_at DateTime @default(now())

  tool_sets          tool_sets[]
  tool_product_lines tool_product_lines[]
}

/// Individual needle/hook product lines from popular brands (e.g. "Red Lace Fixed Circulars")
model tool_product_lines {
  id         String   @id @default(uuid())
  brand_id   String
  name       String   // "Red Lace Fixed Circulars"
  // "circular" | "straight" | "dpn" | "crochet_hook"
  type       String
  material   String?  // stainless_steel, bamboo, wood, aluminum, etc.
  // JSON array: [{mm: 2.0, label: "US 0"}, {mm: 2.25, label: "US 1"}, ...]
  sizes      Json?
  // JSON array of available total lengths in cm: [41, 61, 81, 102] or null
  lengths_cm Json?
  image_url  String?
  created_at DateTime @default(now())

  brand tool_brands @relation(fields: [brand_id], references: [id], onDelete: Cascade)

  @@unique([brand_id, name])
  @@index([brand_id])
  @@index([type])
}

// Pre-populated catalog of needle/hook sets
model tool_sets {
  id          String   @id @default(uuid())
  brand_id    String
  name        String   // "TWIST Red Lace 5-Inch Complete Set"
  // "interchangeable_knitting" | "interchangeable_crochet" | "straight_set" |
  // "dpn_set" | "crochet_hook_set" | "circular_set"
  set_type    String
  description String?
  image_url   String?  // product photo URL
  // "seed" | "ai_lookup"
  source      String   @default("seed")
  created_at  DateTime @default(now())

  brand tool_brands      @relation(fields: [brand_id], references: [id], onDelete: Cascade)
  items tool_set_items[]

  @@unique([brand_id, name])
  @@index([brand_id])
  @@index([set_type])
}

// Individual items within a set (auto-added to user's stash when they select the set)
model tool_set_items {
  id         String @id @default(uuid())
  set_id     String
  // "straight" | "circular" | "dpn" | "crochet_hook" |
  // "interchangeable_tip" | "interchangeable_cable"
  type       String
  size_mm    Float    // 0 for cables
  size_label String?  // "US 7", "4.5mm", "G/6"
  length_cm  Int?     // cable/needle length
  // "stainless_steel" | "bamboo" | "wood" | "aluminum" | "plastic" | "carbon_fiber"
  material   String?
  quantity   Int      @default(1) // e.g. 2 tips per size in interchangeable sets
  sort_order Int      @default(0)

  set tool_sets @relation(fields: [set_id], references: [id], onDelete: Cascade)

  @@index([set_id])
}

// ─── Needles & Hooks ──────────────────────────────────────────────────────────

model user_needles {
  id          String   @id @default(uuid())
  user_id     String
  // "straight" | "circular" | "dpn" | "crochet_hook" |
  // "interchangeable_tip" | "interchangeable_cable"
  type        String
  size_mm     Float
  size_label  String?  // human label: "US 7", "4.5mm", "G/6"
  length_cm   Int?     // for circulars/cables
  // "bamboo" | "metal" | "wood" | "plastic" | "steel" |
  // "stainless_steel" | "aluminum" | "carbon_fiber"
  material    String?
  brand       String?
  notes       String?
  tool_set_id String?  // which catalog set this was added from (if any)
  ravelry_id  String?
  created_at  DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, ravelry_id])
  @@index([user_id])
}

// ─── Supplies & Notions ──────────────────────────────────────────────────────

model user_supplies {
  id         String   @id @default(uuid())
  user_id    String
  name       String   // "Stitch markers (set of 20)"
  // "stitch_markers" | "tape_measure" | "scissors" | "row_counter" |
  // "cable_needles" | "stitch_holders" | "blocking_mats" | "blocking_pins" |
  // "yarn_bowl" | "swift" | "ball_winder" | "darning_needles" |
  // "pom_pom_maker" | "other"
  category   String   @default("other")
  brand      String?
  quantity   Int      @default(1)
  notes      String?
  photo_url  String?  // Supabase Storage public URL
  photo_path String?  // Storage path for deletion
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

// ─── Projects ─────────────────────────────────────────────────────────────────

model projects {
  id                String    @id @default(uuid())
  user_id           String
  pattern_id        String?   // linked saved pattern (optional)
  slug              String
  title             String
  description       String?
  status            String    @default("active") // "active" | "completed" | "frogged" | "hibernating"
  craft_type        String    @default("knitting") // "knitting" | "crochet"
  is_public         Boolean   @default(false)
  size_made         String?   // e.g. "Small", "36\" bust"
  mods_notes        String?   // modifications to the pattern
  category          String?   // e.g. "Feet / Legs → Socks → Mid-calf"
  ravelry_id        String?
  ravelry_permalink String?
  pdf_upload_id     String?   // attached PDF for reference while working
  started_at        DateTime?
  finished_at       DateTime?
  deleted_at        DateTime?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  user              users              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pattern           patterns?          @relation(fields: [pattern_id], references: [id], onDelete: SetNull)
  pdf_upload        pdf_uploads?       @relation(fields: [pdf_upload_id], references: [id], onDelete: SetNull)
  sections          project_sections[]
  gauge             project_gauge?
  photos            project_photos[]
  yarns             project_yarns[]
  tags              project_tags[]
  posts             posts[]
  activity_events   activity_events[]
  pattern_reviews   pattern_reviews[]
  crafting_sessions crafting_sessions[]

  @@unique([user_id, slug])
  @@unique([user_id, ravelry_id])
  @@index([user_id])
  @@index([deleted_at])
  @@index([is_public])
}

model project_sections {
  id                 String   @id @default(uuid())
  project_id         String
  pattern_section_id String?  // link to pattern section for instruction lookup
  name               String
  description        String?
  target_rows        Int?     // total taps across all steps (estimated for open-ended steps)
  current_row        Int      @default(0) // total taps within current step
  current_step       Int      @default(1) // which instruction step the knitter is on (1-based)
  sort_order         Int      @default(0)
  completed          Boolean  @default(false) // true when all steps finished
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  project         projects              @relation(fields: [project_id], references: [id], onDelete: Cascade)
  pattern_section pattern_sections?     @relation(fields: [pattern_section_id], references: [id], onDelete: SetNull)
  row_history     row_counter_history[]
  step_notes      step_notes[]
  step_overrides  step_overrides[]

  @@index([project_id])
  @@index([pattern_section_id])
}

model row_counter_history {
  id         String   @id @default(uuid())
  section_id String
  action     String   // "increment" | "decrement" | "reset" | "set"
  value      Int
  previous   Int
  created_at DateTime @default(now())

  section project_sections @relation(fields: [section_id], references: [id], onDelete: Cascade)

  @@index([section_id])
}

model project_gauge {
  id                String @id @default(uuid())
  project_id        String @unique
  stitches_per_10cm Float?
  rows_per_10cm     Float?
  needle_size_mm    Float?
  yarn_weight       String?

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
}

model project_photos {
  id         String   @id @default(uuid())
  project_id String
  url        String
  caption    String?
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
}

// ─── Pattern Folders ─────────────────────────────────────────────────────────

model pattern_folders {
  id         String    @id @default(uuid())
  user_id    String
  parent_id  String?
  name       String
  color      String?   // hex color for folder icon, e.g. "#FF6B6B"
  sort_order Int       @default(0)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  user     users              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  parent   pattern_folders?   @relation("folder_tree", fields: [parent_id], references: [id], onDelete: Cascade)
  children pattern_folders[]  @relation("folder_tree")
  patterns patterns[]

  @@unique([user_id, parent_id, name])
  @@index([user_id])
  @@index([parent_id])
}

// ─── Patterns ─────────────────────────────────────────────────────────────────

model patterns {
  id              String    @id @default(uuid())
  user_id         String
  folder_id       String?
  slug            String
  title           String
  description     String?
  craft_type      String    @default("knitting")
  // "beginner" | "easy" | "intermediate" | "advanced" | "experienced"
  difficulty      String?
  garment_type    String?
  designer_name   String?
  brand_name      String?
  yarn_weight     String?
  needle_size_mm  Float?
  needle_sizes    String[]          // all needle sizes as labels, e.g. ["US 4 - 3.5mm", "US 6 - 4mm"]
  sizes_available String?           // raw sizes string from Ravelry, e.g. "XS / S / M / L / XL"
  yardage_min           Int?
  yardage_max           Int?
  gauge_stitches_per_10cm Float?  // for AI agent pattern matching
  gauge_rows_per_10cm   Float?   // for AI agent pattern matching
  gauge_stitch_pattern  String?  // e.g. "stockinette stitch", "1 x 1 rib (k1, p1)"
  rating          Float?
  rating_count    Int?
  source_url      String?
  pdf_url         String?   // Supabase Storage URL
  cover_image_url String?
  notes_html      String?   @db.Text  // HTML formatted notes from Ravelry
  is_public       Boolean   @default(false)
  // true = original/free content (can be shared publicly)
  // false = from paid PDF or paid Ravelry pattern (must stay private)
  // null = unknown (treat as private)
  source_free     Boolean?
  ravelry_id      String?
  ai_parsed       Boolean   @default(false)
  raw_text        String?   @db.Text  // stored PDF text for re-parsing with different size
  selected_size   String?             // which size was parsed row-by-row ("M", "XL", etc.)
  parse_version   Int       @default(1)
  deleted_at      DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  user            users             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  folder          pattern_folders?  @relation(fields: [folder_id], references: [id], onDelete: SetNull)
  sections        pattern_sections[]
  sizes           pattern_sizes[]
  photos          pattern_photos[]
  projects        projects[]
  queue           pattern_queue[]
  tags            pattern_tags[]
  pdf_uploads     pdf_uploads[]
  reviews         pattern_reviews[]
  activity_events activity_events[]

  @@unique([user_id, slug])
  @@unique([user_id, ravelry_id])
  @@index([user_id])
  @@index([folder_id])
  @@index([is_public])
}

model pattern_sections {
  id         String   @id @default(uuid())
  pattern_id String
  size_id    String?  // null = size-agnostic shell from Stage 1; set = size-specific from Stage 2
  name       String
  content    String?
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  pat              patterns            @relation(fields: [pattern_id], references: [id], onDelete: Cascade)
  size             pattern_sizes?      @relation(fields: [size_id], references: [id], onDelete: Cascade)
  rows             pattern_rows[]
  project_sections project_sections[]

  @@index([pattern_id])
  @@index([size_id])
}

// Each "row" is actually an instruction step — may represent 1 tap, N taps, or open-ended work.
// The step_number is the display order within a section. The counter tracks taps within a step.
model pattern_rows {
  id              String   @id @default(uuid())
  section_id      String
  row_number      Int               // step number within section (1-based)
  instruction     String            // display text for this step (resolved for selected size)
  notes           String?
  stitch_count    Int?              // expected stitches after completing this step
  // "setup" = one-time action (CO, join, slip sts)
  // "work_rows" = fixed set of rows to work through
  // "repeat" = a block that repeats N times
  // "work_to_measurement" = knit until piece reaches a measurement (open-ended)
  // "finishing" = bind off, seaming, weave in ends
  row_type        String?
  rows_in_step    Int?              // how many counter taps this step takes (null = open-ended)
  is_repeat       Boolean   @default(false)
  repeat_count    Int?              // how many times the block repeats
  rows_per_repeat Int?              // rows in each repeat cycle (e.g. 2 for RS+WS pair)
  target_measurement_cm Float?      // for work_to_measurement steps
  created_at      DateTime  @default(now())

  size_id    String?
  size       pattern_sizes?    @relation(fields: [size_id], references: [id], onDelete: Cascade)

  section pattern_sections @relation(fields: [section_id], references: [id], onDelete: Cascade)

  @@index([section_id])
  @@index([size_id])
}

// Photos associated with a pattern (carousel images from Ravelry or user uploads)
model pattern_photos {
  id         String @id @default(uuid())
  pattern_id String
  url        String   // full image URL
  sort_order Int      @default(0)
  caption    String?

  pattern patterns @relation(fields: [pattern_id], references: [id], onDelete: Cascade)

  @@index([pattern_id])
}

// Sizes included in a pattern (e.g. XS / S / M or 32" / 34" / 36")
model pattern_sizes {
  id                 String @id @default(uuid())
  pattern_id         String
  name               String // "XS", "S/M", "36\" bust"
  sort_order         Int    @default(0)
  finished_bust_cm   Float?
  finished_length_cm Float?
  hip_cm               Float?
  shoulder_width_cm    Float?
  arm_length_cm        Float?
  upper_arm_cm         Float?
  back_length_cm       Float?
  head_circumference_cm Float?
  foot_length_cm       Float?
  yardage            Int?

  pattern  patterns           @relation(fields: [pattern_id], references: [id], onDelete: Cascade)
  sections pattern_sections[]
  rows     pattern_rows[]

  @@index([pattern_id])
}

// ─── Tags ─────────────────────────────────────────────────────────────────────

model tags {
  id   String @id @default(uuid())
  name String @unique

  project_tags project_tags[]
  pattern_tags pattern_tags[]
}

model project_tags {
  project_id String
  tag_id     String

  project projects @relation(fields: [project_id], references: [id], onDelete: Cascade)
  tag     tags     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([project_id, tag_id])
}

model pattern_tags {
  pattern_id String
  tag_id     String

  pattern patterns @relation(fields: [pattern_id], references: [id], onDelete: Cascade)
  tag     tags     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([pattern_id, tag_id])
}

// ─── Pattern Queue (Want to Make) ─────────────────────────────────────────────

model pattern_queue {
  id               String   @id @default(uuid())
  user_id          String
  pattern_id       String
  pdf_upload_id    String?  // attached PDF for reference
  notes            String?
  sort_order       Int      @default(0)
  ravelry_queue_id String?
  created_at       DateTime @default(now())

  user       users        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pattern    patterns     @relation(fields: [pattern_id], references: [id], onDelete: Cascade)
  pdf_upload pdf_uploads? @relation(fields: [pdf_upload_id], references: [id], onDelete: SetNull)

  @@unique([user_id, pattern_id])
  @@unique([user_id, ravelry_queue_id])
  @@index([user_id])
}

// ─── Saved Ravelry Patterns (lightweight snapshots) ──────────────────────────

// Snapshot of a Ravelry pattern the user explicitly saved/bookmarked.
// Never store search results here — just patterns the user chose to keep.
model saved_patterns {
  id            String   @id @default(uuid())
  user_id       String
  ravelry_id    Int      // Ravelry pattern ID
  name          String
  permalink     String   // Ravelry permalink slug
  craft         String   // "knitting" | "crochet"
  weight        String?  // "fingering" | "dk" | "worsted" etc.
  yardage_min   Int?
  yardage_max   Int?
  gauge         String?  // e.g. "20 stitches = 4 inches"
  needle_sizes  String[] // e.g. ["US 7", "4.5mm"]
  difficulty    Float?   // 1-10 scale from Ravelry
  photo_url     String?  // relative path — prepend https://images4.ravelry.com
  designer      String?
  free          Boolean  @default(false)
  created_at    DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, ravelry_id])
  @@index([user_id])
  @@index([user_id, weight])
}

// ─── Social ───────────────────────────────────────────────────────────────────

model posts {
  id         String    @id @default(uuid())
  user_id    String
  content    String
  project_id String?
  deleted_at DateTime?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  user      users            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project   projects?        @relation(fields: [project_id], references: [id], onDelete: SetNull)
  photos    post_photos[]
  comments  comments[]
  likes     likes[]
  bookmarks post_bookmarks[]

  @@index([user_id])
  @@index([created_at])
}

// Multiple photos per post
model post_photos {
  id         String   @id @default(uuid())
  post_id    String
  url        String
  sort_order Int      @default(0)
  created_at DateTime @default(now())

  post posts @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@index([post_id])
}

model post_bookmarks {
  user_id    String
  post_id    String
  created_at DateTime @default(now())

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post posts @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@id([user_id, post_id])
}

// Comments on posts OR activity events (exactly one parent must be set)
model comments {
  id                String    @id @default(uuid())
  user_id           String
  post_id           String?
  activity_event_id String?
  content           String
  deleted_at        DateTime?
  created_at        DateTime  @default(now())

  user           users            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post           posts?           @relation(fields: [post_id], references: [id], onDelete: Cascade)
  activity_event activity_events? @relation(fields: [activity_event_id], references: [id], onDelete: Cascade)

  @@index([post_id])
  @@index([activity_event_id])
}

// Likes/reactions on posts OR activity events (exactly one parent must be set)
model likes {
  id                String   @id @default(uuid())
  user_id           String
  post_id           String?
  activity_event_id String?
  // null = simple like, or emoji reaction: "❤️" | "🔥" | "🧶" | "👏" | "😍"
  reaction          String?
  created_at        DateTime @default(now())

  user           users            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  post           posts?           @relation(fields: [post_id], references: [id], onDelete: Cascade)
  activity_event activity_events? @relation(fields: [activity_event_id], references: [id], onDelete: Cascade)

  @@unique([user_id, post_id])
  @@unique([user_id, activity_event_id, reaction])
  @@index([post_id])
  @@index([activity_event_id])
}

model follows {
  id           String   @id @default(uuid())
  follower_id  String
  following_id String
  created_at   DateTime @default(now())

  follower  users @relation("follower", fields: [follower_id], references: [id], onDelete: Cascade)
  following users @relation("following", fields: [following_id], references: [id], onDelete: Cascade)

  @@unique([follower_id, following_id])
  @@index([follower_id])
  @@index([following_id])
}

model notifications {
  id            String   @id @default(uuid())
  user_id       String
  sender_id     String?
  type          String   // "follow" | "like" | "comment" | "mention"
  resource_type String?  // "post" | "comment" | "project" | "pattern"
  resource_id   String?
  message       String?  // optional display text override
  read          Boolean  @default(false)
  created_at    DateTime @default(now())

  user   users  @relation("recipient", fields: [user_id], references: [id], onDelete: Cascade)
  sender users? @relation("sender", fields: [sender_id], references: [id], onDelete: SetNull)

  @@index([user_id, read])
}

// ─── Tutorials ────────────────────────────────────────────────────────────────

// Seed with standard knitting/crochet tutorials (cast on, knit stitch, etc.)
model tutorials {
  id           String   @id @default(uuid())
  slug         String   @unique
  title        String
  description  String?
  // "cast_on" | "bind_off" | "stitches" | "techniques" | "finishing" | "crochet_basics" | "reading_patterns"
  category     String
  craft_type   String   @default("both") // "knitting" | "crochet" | "both"
  difficulty   String   @default("beginner")
  sort_order   Int      @default(0)
  is_published Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  steps    tutorial_steps[]
  progress user_tutorial_progress[]
}

model tutorial_steps {
  id          String  @id @default(uuid())
  tutorial_id String
  step_number Int
  title       String
  content     String  // markdown
  image_url   String?
  video_url   String?

  tutorial tutorials @relation(fields: [tutorial_id], references: [id], onDelete: Cascade)

  @@index([tutorial_id])
}

model user_tutorial_progress {
  id           String    @id @default(uuid())
  user_id      String
  tutorial_id  String
  completed    Boolean   @default(false)
  last_step    Int       @default(0)
  completed_at DateTime?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  user     users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  tutorial tutorials @relation(fields: [tutorial_id], references: [id], onDelete: Cascade)

  @@unique([user_id, tutorial_id])
  @@index([user_id])
}

// ─── Glossary ─────────────────────────────────────────────────────────────────

model glossary_terms {
  id            String   @id @default(uuid())
  abbreviation  String?              // "SSK", "K2TOG" — null for full-word terms
  name          String               // "Slip Slip Knit", "Knit Two Together"
  slug          String   @unique     // "ssk", "knit-two-together"
  category      String               // decrease, increase, cast_on, bind_off, stitch_pattern, texture, construction, shaping, finishing, tools, measurement, general
  craft_type    String   @default("both") // knitting, crochet, both
  definition    String               // Plain-language explanation
  how_to        String?              // Step-by-step text instructions
  tips          String?              // Common mistakes, pro tips
  video_url        String?              // YouTube video URL (regular or Shorts)
  video_start_s    Int?                 // Start timestamp in seconds
  video_end_s      Int?                 // End timestamp in seconds
  video_is_short   Boolean  @default(false) // true for YouTube Shorts (9:16 portrait)
  video_alternates Json?                // Backup video URLs as JSON array ["url1", "url2"]
  difficulty    String   @default("beginner") // beginner, intermediate, advanced
  sort_order    Int      @default(0)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  synonyms      glossary_synonyms[]

  @@index([category])
  @@index([craft_type])
  @@index([abbreviation])
}

model glossary_synonyms {
  id         String @id @default(uuid())
  term_id    String
  synonym    String          // "sl1-k1-psso" for SSK, regional variants
  region     String?         // "UK", "US", "Japanese" — null if universal

  term       glossary_terms @relation(fields: [term_id], references: [id], onDelete: Cascade)

  @@unique([term_id, synonym])
  @@index([synonym])
}

// ─── PDF Uploads ───────────────────────────────────────────────────────────────

// Tracks PDF uploads for free tier gating (2/month for free users).
model pdf_uploads {
  id           String   @id @default(uuid())
  user_id      String
  pattern_id   String?  // linked pattern if AI-parsed in future
  file_name    String
  file_size    Int      // bytes
  // "stored" | "parsed" | "failed"
  status       String   @default("stored")
  storage_path String   // path in Supabase Storage bucket (private)
  error        String?
  created_at   DateTime @default(now())

  user          users          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pattern       patterns?      @relation(fields: [pattern_id], references: [id], onDelete: SetNull)
  projects      projects[]
  queue_items   pattern_queue[]

  @@index([user_id])
  @@index([user_id, created_at])
}

// ─── Activity Feed ──────────────────────────────────────────────────────────

// Auto-generated events for the social feed (Goodreads/Letterboxd style).
// Created by API routes when users take actions — friends see these in their feed.
model activity_events {
  id         String   @id @default(uuid())
  user_id    String
  // Event types:
  // "project_started" | "project_completed" | "project_frogged" |
  // "pattern_saved" | "pattern_queued" |
  // "review_posted" | "stash_added" |
  // "row_milestone" | "session_logged"
  type       String
  project_id String?
  pattern_id String?
  // Flexible payload: { milestone: 500, row_count: 500 } or { rating: 4.5 } or { duration_minutes: 120 }
  metadata   Json?
  created_at DateTime @default(now())

  user     users      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project  projects?  @relation(fields: [project_id], references: [id], onDelete: SetNull)
  pattern  patterns?  @relation(fields: [pattern_id], references: [id], onDelete: SetNull)
  comments comments[]
  likes    likes[]

  @@index([user_id, created_at])
  @@index([created_at]) // for building the friends feed
}

// ─── Pattern Reviews ────────────────────────────────────────────────────────

// Letterboxd-style reviews — posted when a user finishes a project.
// One review per user per pattern.
model pattern_reviews {
  id                String   @id @default(uuid())
  user_id           String
  pattern_id        String
  project_id        String?  // the project they made from this pattern
  rating            Float    // 1-5 stars (half-star increments)
  difficulty_rating Float?   // 1-5 (how hard was it really?)
  content           String?  // written review
  would_make_again  Boolean?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user    users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  pattern patterns  @relation(fields: [pattern_id], references: [id], onDelete: Cascade)
  project projects? @relation(fields: [project_id], references: [id], onDelete: SetNull)

  @@unique([user_id, pattern_id])
  @@index([pattern_id])
  @@index([user_id])
}

// ─── Crafting Sessions (Activity Heatmap) ───────────────────────────────────

// Tracks time spent crafting — powers the GitHub-contributions-style heatmap.
// Created via in-app timer, row counter auto-tracking, or manual entry.
model crafting_sessions {
  id               String    @id @default(uuid())
  user_id          String
  project_id       String?
  date             DateTime  @db.Date  // the calendar day (for heatmap grouping)
  started_at       DateTime?           // exact start time (if using timer)
  ended_at         DateTime?           // exact end time (if using timer)
  duration_minutes Int                 // total minutes — calculated or manual
  active_minutes   Int?               // time actually knitting (excludes pauses)
  // "timer" = in-app start/stop, "counter" = auto from row counter activity, "manual" = user entered after the fact
  source           String    @default("manual")
  notes            String?
  // Progress tracking — snapshot of where the knitter was
  rows_start       Int?               // counter value at session start
  rows_end         Int?               // counter value at session end
  section_start    String?            // section name when started
  section_end      String?            // section name when ended
  step_start       Int?               // step number at start
  step_end         Int?               // step number at end
  created_at       DateTime  @default(now())

  user    users              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  project projects?          @relation(fields: [project_id], references: [id], onDelete: SetNull)
  pauses  session_pauses[]
  photos  session_photos[]

  @@index([user_id, date])   // heatmap query: group by date for past year
  @@index([user_id, created_at])
  @@index([project_id])
}

// ─── Session Pauses ─────────────────────────────────────────────────────────

// Tracks pause/resume within a session for accurate active time calculation.
model session_pauses {
  id         String    @id @default(uuid())
  session_id String
  paused_at  DateTime
  resumed_at DateTime?

  session crafting_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
}

// ─── Session Photos ─────────────────────────────────────────────────────────

// Progress photos taken during or at the end of a session.
model session_photos {
  id           String   @id @default(uuid())
  session_id   String
  url          String
  storage_path String   // Supabase Storage path for deletion
  caption      String?
  created_at   DateTime @default(now())

  session crafting_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@index([session_id])
}

// ─── Step Notes & Overrides ──────────────────────────────────────────────────

// Notes, modifications, and inline measurements attached to a specific step in a project.
model step_notes {
  id                 String   @id @default(uuid())
  project_section_id String
  step_number        Int      // which step within the section
  content            String
  // "note" = general observation
  // "modification" = change to the instruction
  // "measurement" = inline tape-measure reading
  note_type          String   @default("note")
  measurement_value  Float?   // cm — if note_type = "measurement"
  measurement_target Float?   // cm — the target from the pattern step
  row_at             Int?     // counter tap count when note was added
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  project_section project_sections @relation(fields: [project_section_id], references: [id], onDelete: Cascade)

  @@index([project_section_id])
  @@index([project_section_id, step_number])
}

// User's custom override of an instruction step (their personal version).
// Original pattern_rows is preserved — this takes display priority.
model step_overrides {
  id                 String   @id @default(uuid())
  project_section_id String
  step_number        Int      // which step to override
  custom_instruction String   // user's modified version
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  project_section project_sections @relation(fields: [project_section_id], references: [id], onDelete: Cascade)

  @@unique([project_section_id, step_number])
  @@index([project_section_id])
}

// ─── User Measurements ──────────────────────────────────────────────────────

// Optional body measurements for smart pattern size selection.
// All values stored in cm. Display converts to inches based on unit_preference.
model user_measurements {
  id                    String   @id @default(uuid())
  user_id               String   @unique
  unit_preference       String   @default("cm") // "cm" | "inches"
  // Upper body
  bust_cm               Float?
  waist_cm              Float?
  hip_cm                Float?
  shoulder_width_cm     Float?
  back_length_cm        Float?   // neck to waist
  arm_length_cm         Float?   // shoulder to wrist
  upper_arm_cm          Float?
  wrist_cm              Float?
  // Head (hats, headbands)
  head_circumference_cm Float?
  // Lower body
  inseam_cm             Float?
  // Feet (socks)
  foot_length_cm        Float?
  foot_circumference_cm Float?
  // General
  height_cm             Float?
  notes                 String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ─── Onboarding ───────────────────────────────────────────────────────────────

// Created automatically when user signs up (via Clerk webhook).
// Each boolean tracks one onboarding step so the app knows where to resume.
model user_onboarding {
  id                    String    @id @default(uuid())
  user_id               String    @unique
  welcome_seen          Boolean   @default(false)
  craft_preference_set  Boolean   @default(false)
  experience_level_set  Boolean   @default(false)
  first_project_created Boolean   @default(false)
  first_pattern_saved   Boolean   @default(false)
  counter_tutorial_done Boolean   @default(false)
  ravelry_prompted      Boolean   @default(false)
  onboarding_complete   Boolean   @default(false)
  completed_at          DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  user users @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
